    "/budgets": {
      "get": {
        "tags": ["预算"],
        "summary": "查询预算列表",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "month", "in": "query", "schema": { "type": "string" }, "description": "月份 yyyy-MM" }
